{
  "manifest_version": 3,
  "name": "SnapList AI Autofill",
  "version": "1.0",
  "description": "Automatically fill ecommerce product listings from SnapList AI.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://sellercentral.amazon.com/*",
    "https://seller.flipkart.com/*",
    "https://seller.meesho.com/*",
    "https://*.myshopify.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js", "page_scanner.js", "field_mapper.js", "autofill_engine.js"]
    }
  ]
}
